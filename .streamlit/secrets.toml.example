# GWS Security Auditor - Live Mode Configuration
# Copy this file to secrets.toml and populate with your service account credentials.
# NEVER commit secrets.toml to version control.

[gws]
# Path to your service account JSON key file, OR paste the JSON content directly below.
# Option A: path on disk
# service_account_key_path = "/path/to/key.json"

# Option B: paste the full JSON as a multi-line string
# service_account_key_json = """
# {
#   "type": "service_account",
#   "project_id": "your-project-id",
#   "private_key_id": "...",
#   "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
#   "client_email": "auditor@your-project.iam.gserviceaccount.com",
#   "client_id": "...",
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token"
# }
# """

# The GWS super admin account to impersonate via domain-wide delegation
admin_email = "admin@yourdomain.com"

# Your primary domain
domain = "yourdomain.com"

# Required OAuth scopes for the service account:
# - https://www.googleapis.com/auth/admin.directory.user.readonly
# - https://www.googleapis.com/auth/admin.directory.group.readonly
# - https://www.googleapis.com/auth/admin.reports.audit.readonly
# - https://www.googleapis.com/auth/apps.alerts
